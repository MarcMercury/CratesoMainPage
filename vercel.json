{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/products/hottiesthathit", "destination": "/products/hottiesthathit/index.html" },
    { "source": "/products/nycdeli", "destination": "/products/nycdeli/index.html" },
    { "source": "/products/petpodcast", "destination": "/products/petpodcast/index.html" },
    { "source": "/products/stooppolitics", "destination": "/products/stooppolitics/index.html" }
  ]
}
